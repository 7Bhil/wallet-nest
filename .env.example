# ==========================================
# ENV TEMPLATE — NESTJS BACKEND (PRODUCTION)
# ==========================================

# Port d'écoute du serveur (Render/Railway affectent généralement le port dynamiquement)
PORT=5000

# L'environnement (important pour l'optimisation)
NODE_ENV=production

# Base de données (Remplacer par l'URL de MongoDB Atlas)
# Exemple: mongodb+srv://<admin>:<password>@cluster0.abcde.mongodb.net/wallet?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/wallet

# Sécurité: Clé secrète JWT pour signer les tokens (Génère une chaîne longue et aléatoire)
JWT_SECRET=generer-une-cle-secrete-tres-longue-en-production

# URLs Frontend Autorisées (CORS) - Séparées par une virgule si plusieurs
# Exemple: https://mon-super-wallet.vercel.app,https://www.mon-super-wallet.com
FRONTEND_URL=https://wallet-app-frontend.vercel.app

# Identifiants de l'administrateur initial (Uniquement pour le premier lancement)
ADMIN_EMAIL=admin@votre-domaine.com
ADMIN_PASSWORD=choisissez-un-password-tres-robuste
